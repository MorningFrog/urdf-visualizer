{
    "name": "urdf-visualizer",
    "displayName": "%extension.displayName%",
    "description": "%extension.description%",
    "repository": {
        "type": "git",
        "url": "https://github.com/MorningFrog/urdf-visualizer"
    },
    "version": "5.0.1",
    "publisher": "morningfrog",
    "engines": {
        "vscode": "^1.70.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:xml",
        "onCommand:urdf-visualizer.previewURDFXacro"
    ],
    "icon": "media/icons/URDF-Visualizer.png",
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "urdf-visualizer.previewURDFXacro",
                "title": "%extension.commands.previewURDFXacro.title%",
                "category": "URDF Visualizer",
                "icon": "$(eye)"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "urdf-visualizer.previewURDFXacro",
                    "when": "resourceExtname == .urdf || resourceExtname == .xacro || resourceExtname == .URDF",
                    "group": "navigation"
                }
            ]
        },
        "configuration": {
            "type": "object",
            "title": "%extension.configuration.title%",
            "properties": {
                "urdf-visualizer.packages": {
                    "type": "object",
                    "default": {},
                    "description": "%extension.configuration.packages.description%"
                },
                "urdf-visualizer.renderOnSave": {
                    "type": "boolean",
                    "default": true,
                    "description": "%extension.configuration.renderOnSave.description%"
                },
                "urdf-visualizer.reRenderWhenSwitchFile": {
                    "type": "boolean",
                    "default": true,
                    "description": "%extension.configuration.reRenderWhenSwitchFile.description%"
                },
                "urdf-visualizer.cacheCameraView": {
                    "type": "boolean",
                    "default": true,
                    "description": "%extension.configuration.cacheCameraView.description%"
                },
                "urdf-visualizer.cacheJointValues": {
                    "type": "boolean",
                    "default": false,
                    "description": "%extension.configuration.cacheJointValues.description%"
                },
                "urdf-visualizer.cacheMesh": {
                    "type": "boolean",
                    "default": true,
                    "description": "%extension.configuration.cacheMesh.description%"
                },
                "urdf-visualizer.default.showVisual": {
                    "type": "boolean",
                    "default": true,
                    "description": "%extension.configuration.showVisual.description%"
                },
                "urdf-visualizer.default.showCollision": {
                    "type": "boolean",
                    "default": false,
                    "description": "%extension.configuration.showCollision.description%"
                },
                "urdf-visualizer.default.showWorldFrame": {
                    "type": "boolean",
                    "default": true,
                    "description": "%extension.configuration.showWorldFrame.description%"
                },
                "urdf-visualizer.default.showJointFrames": {
                    "type": "boolean",
                    "default": false,
                    "description": "%extension.configuration.showJointFrames.description%"
                },
                "urdf-visualizer.default.jointFrameSize": {
                    "type": "number",
                    "default": 0.25,
                    "minimum": 0.01,
                    "maximum": 1,
                    "description": "%extension.configuration.jointFrameSize.description%"
                },
                "urdf-visualizer.default.showLinkFrames": {
                    "type": "boolean",
                    "default": false,
                    "description": "%extension.configuration.showLinkFrames.description%"
                },
                "urdf-visualizer.default.linkFrameSize": {
                    "type": "number",
                    "default": 0.25,
                    "minimum": 0.01,
                    "maximum": 1,
                    "description": "%extension.configuration.linkFrameSize.description%"
                },
                "urdf-visualizer.default.lengthUnit": {
                    "type": "string",
                    "default": "meter",
                    "enum": [
                        "meter",
                        "centimeter",
                        "millimeter"
                    ],
                    "description": "%extension.configuration.lengthUnit.description%"
                },
                "urdf-visualizer.default.angleUnit": {
                    "type": "string",
                    "default": "degree",
                    "enum": [
                        "degree",
                        "radian"
                    ],
                    "description": "%extension.configuration.angleUnit.description%"
                },
                "urdf-visualizer.default.collisionColor": {
                    "type": "string",
                    "default": "rgba(255, 190, 56, 0.35)",
                    "description": "%extension.configuration.collisionColor.description%"
                },
                "urdf-visualizer.backgroundColor": {
                    "type": "string",
                    "default": "#cccccc",
                    "description": "%extension.configuration.backgroundColor.description%",
                    "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
                    "patternErrorMessage": "%extension.configuration.backgroundColor.patternErrorMessage%"
                },
                "urdf-visualizer.showTips": {
                    "type": "boolean",
                    "default": true,
                    "description": "%extension.configuration.showTips.description%"
                },
                "urdf-visualizer.highlightJointWhenHover": {
                    "type": "boolean",
                    "default": true,
                    "description": "%extension.configuration.highlightJointWhenHover.description%"
                },
                "urdf-visualizer.highlightLinkWhenHover": {
                    "type": "boolean",
                    "default": false,
                    "description": "%extension.configuration.highlightLinkWhenHover.description%"
                },
                "urdf-visualizer.default.measurement.precision": {
                    "type": "integer",
                    "default": 2,
                    "minimum": 1,
                    "maximum": 5,
                    "description": "%extension.configuration.measurement.precision.description%"
                },
                "urdf-visualizer.default.measurement.useSciNotation": {
                    "type": "boolean",
                    "default": false,
                    "description": "%extension.configuration.measurement.useSciNotation.description%"
                },
                "urdf-visualizer.default.measurement.labelSize": {
                    "type": "integer",
                    "default": 8,
                    "minimum": 1,
                    "maximum": 30,
                    "description": "%extension.configuration.measurement.labelSize.description%"
                },
                "urdf-visualizer.default.measurement.labelColor": {
                    "type": "string",
                    "default": "#000000",
                    "description": "%extension.configuration.measurement.labelColor.description%"
                },
                "urdf-visualizer.default.measurement.lineColor": {
                    "type": "string",
                    "default": "rgba(255, 0, 0, 0.8)",
                    "description": "%extension.configuration.measurement.lineColor.description%"
                },
                "urdf-visualizer.default.measurement.lineThickness": {
                    "type": "integer",
                    "default": 1,
                    "minimum": 1,
                    "maximum": 10,
                    "description": "%extension.configuration.measurement.lineThickness.description%"
                },
                "urdf-visualizer.default.measurement.pointColor": {
                    "type": "string",
                    "default": "rgba(255, 80, 0, 0.6)",
                    "description": "%extension.configuration.measurement.pointColor.description%"
                },
                "urdf-visualizer.default.measurement.pointSize": {
                    "type": "integer",
                    "default": 10,
                    "minimum": 1,
                    "maximum": 30,
                    "description": "%extension.configuration.measurement.pointSize.description%"
                },
                "urdf-visualizer.default.measurement.surfaceColor": {
                    "type": "string",
                    "default": "rgba(135, 206, 250, 0.3)",
                    "description": "%extension.configuration.measurement.surfaceColor.description%"
                }
            }
        }
    },
    "scripts": {
        "webview:install": "npm install --prefix webview",
        "webview:build": "npm run build --prefix webview",
        "webview:watch": "npm run build:watch --prefix webview",
        "webview:dev": "npm run dev --prefix webview",
        "compile": "npm run webview:build && webpack",
        "ext:watch": "webpack --watch",
        "watch": "npm-run-all --parallel webview:watch ext:watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run webview:build && npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint src",
        "test": "vscode-test",
        "vscode:prepublish": "npm run webview:build && npm run package",
        "vscode:package": "npx @vscode/vsce package --no-dependencies",
        "vscode:publish": "npx @vscode/vsce publish --no-dependencies",
        "postinstall": "npm run webview:install"
    },
    "devDependencies": {
        "@eslint-community/eslint-utils": "^4.9.1",
        "@eslint-community/regexpp": "^4.11.1",
        "@eslint/config-array": "^0.23.5",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@eslint/object-schema": "^3.0.5",
        "@eslint/plugin-kit": "^0.7.1",
        "@types/fs-extra": "^11.0.4",
        "@types/mocha": "^10.0.7",
        "@types/node": "25.6.0",
        "@types/three": "^0.183.1",
        "@types/vscode": "^1.70.0",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "@typescript-eslint/scope-manager": "^8.58.1",
        "@typescript-eslint/type-utils": "^8.58.1",
        "@typescript-eslint/types": "^8.58.1",
        "@typescript-eslint/typescript-estree": "^8.58.1",
        "@typescript-eslint/utils": "^8.58.1",
        "@typescript-eslint/visitor-keys": "^8.58.1",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.4.1",
        "eslint": "^10.2.0",
        "eslint-scope": "^9.1.2",
        "eslint-visitor-keys": "^5.0.1",
        "npm-run-all": "^4.1.5",
        "ts-loader": "^9.5.7",
        "typescript": "^6.0.2",
        "webpack": "^5.106.1",
        "webpack-cli": "^7.0.2"
    },
    "dependencies": {
        "expr-eval": "^2.0.2",
        "fs-extra": "^11.3.4",
        "jsdom": "^29.0.2",
        "three": "^0.183.0",
        "urdf-loader": "^0.12.7",
        "xacro-parser": "^0.3.9",
        "xmldom": "^0.6.0"
    }
}